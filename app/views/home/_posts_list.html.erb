<div class="space-y-4">
  <% @posts.each do |post| %>
    <div class="border-b border-gray-200 pb-4 last:border-b-0 last:pb-0">
      <h3 class="text-xl font-semibold text-gray-800"><%= post.name %></h3>
      <% if post.description.present? %>
        <p class="text-gray-600 mt-1"><%= post.description %></p>
      <% end %>
    </div>
  <% end %>
</div>
