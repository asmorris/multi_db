  <h1 class="text-5xl font-bold text-center mb-8">Here's a list of my posts</h1>

  <div id="garby"></div>
  <!-- Form for creating new posts -->
  <div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <h2 class="text-2xl font-bold mb-4">Add a New Post</h2>
    <div data-signals="{ post: {name: '', description: ''} }">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
          <input type="text" 
                 data-bind="post.name"
                 class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
                 placeholder="Enter post name">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea rows="3" 
                    data-bind="post.description"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" 
                    placeholder="Describe your post..."></textarea>
        </div>
        
        <div class="flex justify-end">
          <button data-on-click="@post('/posts')"
                  class="bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-md transition-colors duration-200">
            Create post
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- List of existing posts -->
  <div class="bg-white rounded-lg shadow-md p-6" id="posts-list">
    <h2 class="text-3xl font-bold mb-6 text-center">posts</h2>
    
    <% if @posts.any? %>
      <div id="posts-container">
        <%= render 'posts_list' %>
      </div>
    <% else %>
      <div id="farts-container">
        <p class="text-gray-500 text-center italic">No posts yet. Create your first one above!</p>
      </div>
    <% end %>
  </div>
</div>
