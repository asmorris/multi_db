<!-- Example Badge Components -->
<div class="mb-8 space-y-4">
  <h2 class="text-2xl font-bold mb-4">Badge Component Examples</h2>
  
  <!-- Basic Badges Row -->
  <div class="flex flex-wrap gap-2">
    <%= component 'badge' do %>Badge<% end %>
    <%= render(Badge::Component.new(variant: :secondary)) do %>Secondary<% end %>
    <%= render(Badge::Component.new(variant: :destructive)) do %>Destructive<% end %>
    <%= render(Badge::Component.new(variant: :outline)) do %>Outline<% end %>
  </div>

  <!-- Badges with Icons and Numbers -->
  <div class="flex flex-wrap gap-2">
    <%= render(Badge::Component.new(variant: :secondary, icon: "check", html_attributes: { class: "bg-blue-500 text-white" })) do %>
      Verified
    <% end %>
    
    <%= render(Badge::Component.new(html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>8<% end %>
    <%= render(Badge::Component.new(variant: :destructive, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>99<% end %>
    <%= render(Badge::Component.new(variant: :outline, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>20+<% end %>
  </div>
</div>

<!-- Example Card Components -->
<div class="mb-8 space-y-4">
  <h2 class="text-2xl font-bold mb-4">Card Component Examples</h2>
  
  <!-- Basic Card -->
  <%= render(Card::Component.new(title: "Basic Card", subtitle: "This is a basic card example")) do %>
    <p class="text-gray-600">This is the content of a basic card component with shadcn-inspired styling.</p>
  <% end %>
  
  <!-- Elevated Card -->
  <%= render(Card::Component.new(title: "Elevated Card", variant: :elevated)) do %>
    <p class="text-gray-600">This card has an elevated shadow for more prominence.</p>
  <% end %>
  
  <!-- Card with Footer -->
  <%= render(Card::Component.new(
    title: "Card with Footer", 
    subtitle: "Example with footer",
    footer: content_tag(:div, class: "flex gap-2") do
      content_tag(:button, "Action", class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-md text-sm") +
      content_tag(:button, "Cancel", class: "text-gray-500 hover:text-gray-700 px-4 py-2 text-sm")
    end
  )) do %>
    <p class="text-gray-600">This card demonstrates footer content using the footer parameter.</p>
  <% end %>
</div>


  <h1 class="text-5xl font-bold text-center mb-8">Here's a list of my posts</h1>

  <!-- Form for creating new posts -->
  <div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <h2 class="text-2xl font-bold mb-4">Add a New Post</h2>
    <%= form_with model: @post, local: true, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :name, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", placeholder: "Enter post name" %>
        <% if @post.errors[:name].any? %>
          <div class="text-red-600 text-sm mt-1"><%= @post.errors[:name].first %></div>
        <% end %>
      </div>
      
      <div>
        <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :description, rows: 3, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none", placeholder: "Describe your post..." %>
        <% if @post.errors[:description].any? %>
          <div class="text-red-600 text-sm mt-1"><%= @post.errors[:description].first %></div>
        <% end %>
      </div>
      
      <div class="flex justify-end">
        <%= form.submit "Create post", class: "bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-md transition-colors duration-200" %>
      </div>
    <% end %>
  </div>

  <!-- List of existing posts -->
  <div class="bg-white rounded-lg shadow-md p-6" id="posts-list">
    <h2 class="text-3xl font-bold mb-6 text-center">posts</h2>
    
    <% if @posts.any? %>
      <div id="posts-container">
        <%= render 'posts_list' %>
      </div>
    <% else %>
      <div id="farts-container">
        <p class="text-gray-500 text-center italic">No posts yet. Create your first one above!</p>
      </div>
    <% end %>
  </div>
</div>
