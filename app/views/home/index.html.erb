<div class="max-w-4xl mx-auto p-6">


<!-- Example Badge Components -->
<div class="mb-8 space-y-4">
  <h2 class="font-bold mb-4">Badge Component Examples</h2>

  <!-- Basic Badges Row -->
  <div class="flex flex-wrap gap-2">
    <%= component 'badge' do %>Badge<% end %>
    <%= render(Badge::Component.new(variant: :secondary)) do %>Secondary<% end %>
    <%= render(Badge::Component.new(variant: :destructive)) do %>Destructive<% end %>
    <%= render(Badge::Component.new(variant: :outline)) do %>Outline<% end %>
  </div>

  <!-- Badges with Icons and Numbers -->
  <div class="flex flex-wrap gap-2">
    <%= render(Badge::Component.new(variant: :secondary, icon: "check", html_attributes: { class: "bg-blue-500 text-white" })) do %>
      Verified
    <% end %>

    <%= render(Badge::Component.new(html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>8<% end %>
    <%= render(Badge::Component.new(variant: :destructive, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>99<% end %>
    <%= render(Badge::Component.new(variant: :outline, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>20+<% end %>
  </div>
</div>

<!-- Example Datastar Get Req -->
  <h2 class="font-bold mb-4">DataStar Get Request Example</h2>
<div
  data-signals="{response: '', answer: ''}"
  data-computed-correct="$response.toLowerCase() == $answer"
>
  <div id="question"></div>
  <button class="bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-md transition-colors duration-200"
          data-on-click="@get('/test')"
          data-show="$answer === ''"
          >
          Fetch a question
  </button>
  <button
    data-show="$answer != ''"
    class="bg-green-500 hover:bg-green-600 text-white font-medium py-2 px-4 rounded-md transition-colors duration-200"
    data-on-click="$response = prompt('Answer:') ?? ''"
    style="display: none"
  >
    Shoot your shot
  </button>
  <div data-show="$response != ''">
    You answered “<span data-text="$response"></span>”.
    <span data-show="$correct" class="text-green-500">That is correct ✅</span>
    <span data-show="!$correct" class="text-red-500">
      The correct answer is “<span data-text="$answer"></span>” 🤷
    </span>
  </div>
</div>

  <h1 class="text-3xl font-bold text-center mb-8">Here's a list of my posts</h1>

  <!-- Form for creating new posts -->
  <div class="bg-card rounded-lg shadow-md p-6 mb-8 min-w-2xl">
    <h2 class="text-2xl font-bold mb-4">Add a New Post</h2>
    <div data-signals="{ post: {name: '', description: ''} }">
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-card mb-1">Name</label>
          <input type="text" 
                 data-bind="post.name"
                 class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" 
                 placeholder="Enter post name">
        </div>
        
        <div>
          <label class="block text-sm font-medium text-card mb-1">Description</label>
          <textarea rows="3" 
                    data-bind="post.description"
                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none" 
                    placeholder="Describe your post..."></textarea>
        </div>
        
        <div class="flex justify-end">
          <button data-on-click="@post('/posts')"
                  class="bg-blue-500 hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-md transition-colors duration-200">
            Create post
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- List of existing posts -->
  <div class="bg-card rounded-lg shadow-md p-6" id="posts-list">
    <h2 class="text-3xl font-bold mb-6 text-center text-card">Posts</h2>
    <div id="new-posts" class='mb-4'></div>
    
    <% if @posts.any? %>
      <div id="posts-container">
        <%= render 'posts_list' %>
      </div>
    <% else %>
      <div id="farts-container">
        <p class="text-gray-500 text-center italic">No posts yet. Create your first one above!</p>
      </div>
    <% end %>
  </div>
</div>
