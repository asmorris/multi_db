<div class="max-w-4xl mx-auto p-6">

<!-- Example Datastar thing -->
<div
  data-signals="{response: '', answer: ''}"
  data-computed-correct="$response.toLowerCase() == $answer"
>
  <div id="question"></div>
  <button data-on-click="@get('/test')">Fetch a question</button>
  <button
    data-show="$answer != ''"
    data-on-click="$response = prompt('Answer:') ?? ''"
    style="display: none"
  >
    BUZZ
  </button>
  <div data-show="$response != ''">
    You answered “<span data-text="$response"></span>”.
    <span data-show="$correct">That is correct ✅</span>
    <span data-show="!$correct">
      The correct answer is “<span data-text="$answer"></span>” 🤷
    </span>
  </div>
</div>

<!-- Example Badge Components -->
<div class="mb-8 space-y-4">
  <h2 class="text-2xl font-bold mb-4">Badge Component Examples</h2>

  <!-- Basic Badges Row -->
  <div class="flex flex-wrap gap-2">
    <%= component 'badge' do %>Badge<% end %>
    <%= render(Badge::Component.new(variant: :secondary)) do %>Secondary<% end %>
    <%= render(Badge::Component.new(variant: :destructive)) do %>Destructive<% end %>
    <%= render(Badge::Component.new(variant: :outline)) do %>Outline<% end %>
  </div>

  <!-- Badges with Icons and Numbers -->
  <div class="flex flex-wrap gap-2">
    <%= render(Badge::Component.new(variant: :secondary, icon: "check", html_attributes: { class: "bg-blue-500 text-white" })) do %>
      Verified
    <% end %>

    <%= render(Badge::Component.new(html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>8<% end %>
    <%= render(Badge::Component.new(variant: :destructive, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>99<% end %>
    <%= render(Badge::Component.new(variant: :outline, html_attributes: { class: "h-5 min-w-5 rounded-full px-1 font-mono tabular-nums" })) do %>20+<% end %>
  </div>
</div>

